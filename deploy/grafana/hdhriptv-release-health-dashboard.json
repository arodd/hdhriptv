    {
      "id": 5,
      "title": "Playlist Sync Freshness",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${PROM_DS}"
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "expr": "job_scheduler_freshness_seconds{job=\"hdhriptv\",instance=~\"$instance\",job_name=\"playlist_sync\"}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 7200
              },
              {
                "color": "red",
                "value": 14400
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "id": 6,
      "title": "Playlist Sync Errors (30m)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${PROM_DS}"
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(increase(playlist_sync_source_errors_total{job=\"hdhriptv\",instance=~\"$instance\"}[30m])) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "id": 7,
      "title": "Source Read Pause Events by Reason (5m rate)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${PROM_DS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "expr": "sum by (reason) (rate(stream_source_read_pause_events_total{job=\"hdhriptv\",instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 18,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 8,
      "title": "Write Pressure and Slow-Skip Event Rates (5m)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${PROM_DS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "targets": [
        {
          "expr": "sum(rate(stream_subscriber_write_deadline_timeouts_total{job=\"hdhriptv\",instance=~\"$instance\"}[5m]))",
          "legendFormat": "deadline_timeouts",
          "refId": "A"
        },
        {
          "expr": "sum(rate(stream_subscriber_write_short_writes_total{job=\"hdhriptv\",instance=~\"$instance\"}[5m]))",
          "legendFormat": "short_writes",
          "refId": "B"
        },
        {
          "expr": "sum(rate(stream_subscriber_write_deadline_unsupported_total{job=\"hdhriptv\",instance=~\"$instance\"}[5m]))",
          "legendFormat": "deadline_unsupported",
          "refId": "C"
        },
        {
          "expr": "sum(rate(stream_slow_skip_events_total{job=\"hdhriptv\",instance=~\"$instance\"}[5m]))",
          "legendFormat": "slow_skip_events",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 14,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 9,
      "title": "Close Path Risk Counters (30m increase)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${PROM_DS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 13
      },
      "targets": [
        {
          "expr": "sum(increase(stream_close_with_timeout_timeouts_total{job=\"hdhriptv\",instance=~\"$instance\"}[30m])) or vector(0)",
          "legendFormat": "timeouts",
          "refId": "A"
        },
        {
          "expr": "sum(increase(stream_close_with_timeout_late_abandoned_total{job=\"hdhriptv\",instance=~\"$instance\"}[30m])) or vector(0)",
          "legendFormat": "late_abandoned",
          "refId": "B"
        },
        {
          "expr": "sum(increase(stream_close_with_timeout_release_underflow_total{job=\"hdhriptv\",instance=~\"$instance\"}[30m])) or vector(0)",
          "legendFormat": "release_underflow",
          "refId": "C"
        },
        {
          "expr": "sum(increase(stream_close_with_timeout_suppressed_total{job=\"hdhriptv\",instance=~\"$instance\"}[30m])) or vector(0)",
          "legendFormat": "suppressed",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 12,
            "showPoints": "always"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 10,
      "title": "Virtual Tuner Utilization by Source",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${PROM_DS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 13
      },
      "targets": [
        {
          "expr": "stream_virtual_tuner_utilization_ratio{job=\"hdhriptv\",instance=~\"$instance\"}",
          "legendFormat": "{{playlist_source}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.8
              },
              {
                "color": "red",
                "value": 0.95
              }
            ]
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 18,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 11,
      "title": "Playlist Sync Duration p95 by Source",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${PROM_DS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 13
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, playlist_source) (rate(playlist_sync_source_duration_seconds_bucket{job=\"hdhriptv\",instance=~\"$instance\"}[5m])))",
          "legendFormat": "{{playlist_source}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 14,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 12,
      "title": "Current Playlist Items by Source",
      "type": "bargauge",
      "datasource": {
        "type": "prometheus",
        "uid": "${PROM_DS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 21
      },
      "targets": [
        {
          "expr": "playlist_sync_source_items{job=\"hdhriptv\",instance=~\"$instance\"}",
          "instant": true,
          "legendFormat": "{{playlist_source}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "min": 0,
          "color": {
            "mode": "continuous-GrYlRd"
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "text": {}
      }
    },
    {
      "id": 13,
      "title": "Release and Lifecycle Events",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "${LOKI_DS}"
      },
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 8,
        "y": 21
      },
      "targets": [
        {
          "expr": "{nomad_job=\"hdhriptv\",host=~\"$host\"} |~ \"starting server|server stopped|phase=app_version_sync|job finished\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "id": 14,
      "title": "Warning/Error Log Stream",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "${LOKI_DS}"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 29
      },
      "targets": [
        {
          "expr": "{nomad_job=\"hdhriptv\",host=~\"$host\"} |~ \"level=WARN|level=ERROR|panic|fatal\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
