      "targets": [
        {
          "expr": "sum(count_over_time({nomad_job=\"hdhriptv\",host=~\"$host\"} |= \"level=WARN\" [30m]))",
          "legendFormat": "warn",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
