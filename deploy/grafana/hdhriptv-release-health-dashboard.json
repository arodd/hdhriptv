      "targets": [
        {
          "expr": "sum(count_over_time({nomad_job=\"hdhriptv\",host=~\"$host\"} |= \"level=ERROR\" [30m]))",
          "legendFormat": "error",
          "queryType": "instant",
          "refId": "A"
